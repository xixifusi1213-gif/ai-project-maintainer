{
  "name": "ai-project-maintainer",
  "version": "1.2.1",
  "description": "Release readiness gate for AI-coded projects.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xixifusi1213-gif/ai-project-maintainer.git"
  },
  "bugs": {
    "url": "https://github.com/xixifusi1213-gif/ai-project-maintainer/issues"
  },
  "homepage": "https://github.com/xixifusi1213-gif/ai-project-maintainer#readme",
  "keywords": [
    "ai-coding",
    "devsecops",
    "security",
    "production-readiness",
    "github-actions",
    "semgrep",
    "trivy",
    "gitleaks",
    "codex",
    "ai-agents"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "ai-project-maintainer/",
    "assets/",
    "examples/demo-ai-app/.ai-maintainer/",
    "examples/demo-ai-app/package.json",
    "examples/demo-ai-app/package-lock.json",
    "examples/demo-ai-app/README.md",
    "examples/demo-ai-app/scripts/",
    "examples/demo-ai-app/src/",
    "examples/demo-ai-app/test/",
    "examples/oss-case-studies/",
    "docs/",
    "SECURITY.md",
    "TRUST.md",
    "DESIGN.md",
    "README.md"
  ],
  "bin": {
    "ai-project-maintainer": "ai-project-maintainer/scripts/cli.mjs"
  },
  "scripts": {
    "test": "node --test",
    "check": "node ai-project-maintainer/scripts/check-syntax.mjs",
    "cases:verify": "node examples/oss-case-studies/run-oss-case-studies.mjs --verify",
    "smoke:npm": "node ai-project-maintainer/scripts/npm-package-smoke.mjs",
    "smoke:repair-loop": "node examples/demo-ai-app/scripts/run-repair-loop-demo.mjs --json",
    "smoke:connectors:live": "node ai-project-maintainer/scripts/live-connector-smoke.mjs",
    "release:manifest": "node ai-project-maintainer/scripts/release-manifest.mjs",
    "release:verify:pre": "node ai-project-maintainer/scripts/verify-release.mjs --prepublish --version 1.2.1 --tag v1.2.1",
    "release:verify:published": "node ai-project-maintainer/scripts/verify-release.mjs --published --version 1.2.1 --tag v1.2.1"
  },
  "dependencies": {
    "yaml": "2.9.0"
  }
}
